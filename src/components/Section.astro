---
interface Props {
  background?: 'aliceblue' | 'pelicula' | 'amarillo' | 'rosa';
  id?: string;
}
const { background = 'aliceblue', id } = Astro.props;
---
<section id={id} class={`section section--${background}`}>
  <slot />
</section>

<style>
  .section {
    padding-block: var(--space-16);
  }

  @media (min-width: 64em) {
    .section {
      padding-block: var(--space-24);
    }
  }

  .section--aliceblue {
    background: var(--color-aliceblue);
    color: var(--color-pelicula);
  }

  .section--pelicula {
    background: var(--color-pelicula);
    color: var(--color-aliceblue);
  }

  .section--amarillo {
    background: var(--color-amarillo);
    color: var(--color-pelicula);
  }

  .section--rosa {
    background: var(--color-rosa);
    color: var(--color-pelicula);
  }
</style>
