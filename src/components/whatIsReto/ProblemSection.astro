---
import { useTranslations, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const points = [1, 2, 3];
---

<section class="problem-section" aria-labelledby="problem-title">
  <div class="problem-section__inner">
    <div class="problem-section__intro">
      <h2 id="problem-title">{t('whatIsReto.problem.title')}</h2>
      <p>{t('whatIsReto.problem.intro')}</p>
    </div>

    <div class="problem-section__cards">
      {
        points.map((point) => (
          <article class="problem-card">
            <h3>{t(`whatIsReto.problem.point${point}.title`)}</h3>
            <p>{t(`whatIsReto.problem.point${point}.body`)}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .problem-section {
    background: white;
    padding-block: var(--space-24);
    padding-inline: var(--container-padding);
  }

  .problem-section__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    gap: var(--space-12);
  }

  .problem-section__intro {
    max-width: 560px;
  }

  .problem-section__intro p {
    margin-top: var(--space-6);
    color: rgba(32, 30, 30, 0.72);
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
  }

  .problem-section__cards {
    display: grid;
    gap: var(--space-4);
  }

  .problem-card {
    border: 1px solid rgba(32, 30, 30, 0.08);
    border-radius: var(--radius-sm);
    padding: var(--space-6);
    background: var(--color-aliceblue);
  }

  .problem-card h3 {
    font-size: var(--text-h4);
    line-height: 1.2;
  }

  .problem-card p {
    margin-top: var(--space-3);
    color: rgba(32, 30, 30, 0.72);
  }

  @media (min-width: 64em) {
    .problem-section__inner {
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
      align-items: start;
    }
  }

  @media (max-width: 47.999em) {
    .problem-section {
      padding-block: var(--space-16);
    }
  }
</style>
