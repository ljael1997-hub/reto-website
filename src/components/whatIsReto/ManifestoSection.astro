---
import { useTranslations, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="manifesto-section" aria-labelledby="manifesto-title">
  <div class="manifesto-section__inner">
    <h2 id="manifesto-title">{t('whatIsReto.manifesto.title')}</h2>
    <div class="manifesto-section__body">
      <p>{t('whatIsReto.manifesto.body1')}</p>
      <p>{t('whatIsReto.manifesto.body2')}</p>
      <p>{t('whatIsReto.manifesto.body3')}</p>
    </div>
    <blockquote>{t('whatIsReto.manifesto.quote')}</blockquote>
  </div>
</section>

<style>
  .manifesto-section {
    background: var(--color-aliceblue);
    padding-block: var(--space-32);
    padding-inline: var(--container-padding);
  }

  .manifesto-section__inner {
    max-width: 800px;
    margin-inline: auto;
    text-align: center;
  }

  .manifesto-section__body {
    margin-top: var(--space-8);
    display: grid;
    gap: var(--space-6);
    text-align: left;
  }

  .manifesto-section__body p {
    color: rgba(32, 30, 30, 0.76);
    font-size: clamp(1.125rem, 1.5vw, 1.25rem);
  }

  .manifesto-section blockquote {
    margin-top: var(--space-8);
    border-left: 6px solid var(--color-amarillo);
    padding: var(--space-4) 0 var(--space-4) var(--space-6);
    color: var(--color-pelicula);
    font-family: var(--font-body);
    font-size: clamp(1.125rem, 1.7vw, 1.375rem);
    font-style: italic;
    font-weight: 600;
    line-height: 1.5;
    text-align: left;
  }

  @media (max-width: 47.999em) {
    .manifesto-section {
      padding-block: var(--space-24);
    }
  }
</style>
