---
import { useTranslations, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const members = [
  { name: 'Carlos Roca', role: 'CEO' },
  { name: 'Paulina Torres', role: 'Operations Lead', extra: 'M.S.' },
  { name: 'Alexandro Marcelo', role: 'IT Lead' },
  { name: 'Silvia Reyna', role: 'Content Specialist' },
  { name: 'Laura Sandoval', role: 'Admin Specialist' },
  { name: 'Karla Bernal', role: 'Senior Project Manager' },
  { name: 'Majenklis Nedeska', role: 'Senior Project Manager' },
  { name: 'Yoher Vazquez', role: 'IT Analyst' },
  { name: 'Karen Sumano', role: 'Lead Designer' },
  { name: 'Jorge Soto', role: 'Product Lead' },
  { name: 'Esteban Galicia', role: 'Senior Fullstack Developer' },
  { name: 'Sofía Estrada', role: 'Strategic Partnership Analyst' },
  { name: 'Daniela Montaño', role: 'Medical Content Specialist', extra: 'M.D.' },
  { name: 'Armando Roman', role: 'Business Development Analyst' },
  { name: 'Daniel Vela', role: 'AI & Data Lead', extra: 'M.S.' },
  { name: 'Israel Perez', role: 'AI & Data Analyst' },
  { name: 'Arturo Olmos', role: 'Growth Lead' },
  { name: 'Ismael Castillo', role: 'Senior Fullstack Developer' },
  { name: 'Arely Nataren', role: 'Medical Strategist Analyst', extra: 'M.D. LMA' },
  { name: 'Enrique Aznar', role: 'Fraction Head of People' },
  { name: 'Uri Torruco', role: 'Medical Education Lead', extra: 'M.D. M.Ed.' },
];
---

<section class="team-section" aria-labelledby="team-title">
  <div class="team-section__inner">
    <div class="team-section__heading">
      <h2 id="team-title">{t('whatIsReto.team.title')}</h2>
      <p>{t('whatIsReto.team.subtitle')}</p>
    </div>

    <div class="team-grid-wrapper">
      <div class="team-grid">
        {
          members.map((member) => (
            <article class="team-card">
              <div class="team-card__avatar" aria-hidden="true">
                {member.name.split(' ').map(n => n[0]).slice(0,2).join('')}
              </div>
              <h3>{member.name}</h3>
              {member.extra && <span class="team-card__extra">{member.extra}</span>}
              <p>{member.role}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .team-section {
    background: white;
    padding-block: var(--space-24);
    padding-inline: var(--container-padding);
  }

  .team-section__inner {
    max-width: var(--container-max);
    margin-inline: auto;
  }

  .team-section__heading {
    max-width: 760px;
    margin-inline: auto;
    text-align: center;
  }

  .team-section__heading p {
    margin-top: var(--space-4);
    color: rgba(32, 30, 30, 0.72);
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
  }

  .team-grid-wrapper {
    position: relative;
    max-height: 480px;
    overflow-y: auto;
    border-radius: var(--radius-md);
    border: 1px solid rgba(32, 30, 30, 0.08);
    scrollbar-width: thin;
    scrollbar-color: var(--color-amarillo) transparent;
    margin-top: var(--space-12);
  }

  .team-grid-wrapper::-webkit-scrollbar {
    width: 4px;
  }

  .team-grid-wrapper::-webkit-scrollbar-thumb {
    background: var(--color-amarillo);
    border-radius: 2px;
  }

  .team-grid {
    margin-top: 0;
    padding: var(--space-4);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .team-card {
    border: 1px solid rgba(32, 30, 30, 0.08);
    border-radius: var(--radius-sm);
    padding: var(--space-6);
    text-align: center;
    background: var(--color-aliceblue);
  }

  .team-card__avatar {
    width: min(80px, 100%);
    aspect-ratio: 1;
    margin-inline: auto;
    border-radius: 50%;
    background: var(--color-pelicula);
    color: var(--color-amarillo);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .team-card__extra {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-amarillo);
    background: var(--color-pelicula);
    border-radius: var(--radius-pill);
    padding: 2px 8px;
    margin-top: var(--space-1);
  }

  .team-card h3 {
    margin-top: var(--space-6);
    font-size: var(--text-h4);
    line-height: 1.2;
  }

  .team-card p {
    margin-top: var(--space-2);
    color: rgba(32, 30, 30, 0.64);
  }

  @media (min-width: 48em) {
    .team-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 64em) {
    .team-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 47.999em) {
    .team-section {
      padding-block: var(--space-16);
    }
  }
</style>
