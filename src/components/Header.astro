---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: 'es' | 'en';
}
const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const localizedPaths = {
  '/que-es-reto': { es: '/que-es-reto', en: '/en/what-is-reto' },
  '/en/what-is-reto': { es: '/que-es-reto', en: '/en/what-is-reto' },
  '/metodologia': { es: '/metodologia', en: '/en/methodology' },
  '/en/methodology': { es: '/metodologia', en: '/en/methodology' },
  '/rutas-educativas': { es: '/rutas-educativas', en: '/en/learning-paths' },
  '/en/learning-paths': { es: '/rutas-educativas', en: '/en/learning-paths' },
  '/universidades': { es: '/universidades', en: '/en/universities' },
  '/en/universities': { es: '/universidades', en: '/en/universities' },
  '/hospitales': { es: '/hospitales', en: '/en/hospitals' },
  '/en/hospitals': { es: '/hospitales', en: '/en/hospitals' },
  '/industria': { es: '/industria', en: '/en/industry' },
  '/en/industry': { es: '/industria', en: '/en/industry' },
  '/contacto': { es: '/contacto', en: '/en/contact' },
  '/en/contact': { es: '/contacto', en: '/en/contact' },
} as const;
const currentLocalizedPath = localizedPaths[pathname as keyof typeof localizedPaths];
const spanishHref = currentLocalizedPath?.es ?? '/';
const englishHref = currentLocalizedPath?.en ?? '/en/';
---

<header class="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href={lang === 'es' ? '/' : '/en/'} class="header-logo" aria-label="Reto — Inicio">
      <img src="/logos/reto-logo-light.svg" alt="Reto" height="36" />
    </a>

    <!-- Hamburger toggle (CSS-only) -->
    <input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-hidden="true" />
    <label for="nav-toggle" class="nav-toggle-label" aria-label="Abrir menú">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <!-- Nav -->
    <nav class="header-nav" aria-label="Navegación principal">
      <ul class="nav-list" role="list">
        <li><a href={lang === 'es' ? '/#home' : '/en/#home'}>{t('nav.home')}</a></li>
        <li><a href={lang === 'es' ? '/que-es-reto' : '/en/what-is-reto'}>{t('nav.about')}</a></li>
        <li><a href={lang === 'es' ? '/metodologia' : '/en/methodology'}>{t('nav.methodology')}</a></li>
        <li><a href={lang === 'es' ? '/rutas-educativas' : '/en/learning-paths'}>{t('nav.paths')}</a></li>
        <li class="nav-dropdown">
          <details>
            <summary>{t('nav.forYou')}</summary>
            <ul class="nav-dropdown__menu" role="list">
              <li><a href={lang === 'es' ? '/universidades' : '/en/universities'}>{t('nav.universities')}</a></li>
              <li><a href={lang === 'es' ? '/hospitales' : '/en/hospitals'}>{t('nav.hospitals')}</a></li>
              <li><a href={lang === 'es' ? '/industria' : '/en/industry'}>{t('nav.industry')}</a></li>
            </ul>
          </details>
        </li>
        <li><a href={lang === 'es' ? '/faq' : '/faq'}>FAQ</a></li>
        <li><a href={lang === 'es' ? '/contacto' : '/en/contact'}>{t('nav.contact')}</a></li>
      </ul>

      <!-- Selector de idioma -->
      <div class="lang-switcher" aria-label="Selector de idioma">
        <a
          href={spanishHref}
          class={lang === 'es' ? 'lang-link lang-link--active' : 'lang-link'}
          hreflang="es"
        >ES</a>
        <span aria-hidden="true">|</span>
        <a
          href={englishHref}
          class={lang === 'en' ? 'lang-link lang-link--active' : 'lang-link'}
          hreflang="en"
        >EN</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-aliceblue);
    border-bottom: 1px solid rgba(32, 30, 30, 0.08);
  }

  .header-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
    padding-block: var(--space-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  /* Logo */
  .header-logo {
    flex-shrink: 0;
    line-height: 0;
  }

  .header-logo img {
    height: 36px;
    width: auto;
  }

  /* Nav */
  .header-nav {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    list-style: none;
  }

  .nav-list a,
  .nav-list summary {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-small);
    color: var(--color-pelicula);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .nav-list a:hover,
  .nav-list summary:hover {
    color: var(--color-amarillo);
    text-decoration: none;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown details {
    position: relative;
  }

  .nav-dropdown summary {
    list-style: none;
    cursor: pointer;
  }

  .nav-dropdown summary::-webkit-details-marker {
    display: none;
  }

  .nav-dropdown summary::after {
    content: '';
    display: inline-block;
    width: 0.45em;
    height: 0.45em;
    margin-left: var(--space-2);
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: translateY(-0.18em) rotate(45deg);
  }

  .nav-dropdown__menu {
    position: absolute;
    top: calc(100% + var(--space-3));
    right: 0;
    min-width: 180px;
    display: grid;
    gap: var(--space-2);
    list-style: none;
    border: 1px solid rgba(32, 30, 30, 0.08);
    border-radius: var(--radius-sm);
    background: var(--color-aliceblue);
    padding: var(--space-3);
    box-shadow: 0 12px 32px rgba(32, 30, 30, 0.08);
  }

  .nav-dropdown:not(:focus-within) details:not([open]) .nav-dropdown__menu {
    display: none;
  }

  /* Lang switcher */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-small);
    color: rgba(32, 30, 30, 0.4);
  }

  .lang-link {
    font-family: var(--font-body);
    font-weight: 400;
    color: rgba(32, 30, 30, 0.5);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .lang-link:hover {
    color: var(--color-amarillo);
    text-decoration: none;
  }

  .lang-link--active {
    font-weight: 700;
    color: var(--color-pelicula);
  }

  /* Hamburger — hidden on desktop */
  .nav-toggle-input {
    display: none;
  }

  .nav-toggle-label {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    padding: var(--space-2);
    z-index: 110;
  }

  .nav-toggle-label span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-pelicula);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  /* Mobile */
  @media (max-width: 63.999em) {
    .nav-toggle-label {
      display: flex;
    }

    .header-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-aliceblue);
      border-bottom: 1px solid rgba(32, 30, 30, 0.08);
      padding: var(--space-6);
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-6);
    }

    .nav-list {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
      width: 100%;
    }

    .nav-list a,
    .nav-list summary {
      font-size: var(--text-body);
    }

    .nav-dropdown,
    .nav-dropdown details {
      width: 100%;
    }

    .nav-dropdown__menu {
      position: static;
      margin-top: var(--space-3);
      box-shadow: none;
      background: rgba(255, 255, 255, 0.5);
      min-width: 0;
      width: 100%;
    }

    /* Show nav when checkbox is checked */
    .nav-toggle-input:checked ~ .header-nav {
      display: flex;
    }

    /* Animate hamburger → X */
    .nav-toggle-input:checked ~ .nav-toggle-label span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav-toggle-input:checked ~ .nav-toggle-label span:nth-child(2) {
      opacity: 0;
    }
    .nav-toggle-input:checked ~ .nav-toggle-label span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
