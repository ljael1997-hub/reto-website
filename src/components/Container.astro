---
interface Props {
  as?: string;
  class?: string;
}
const { as: Tag = 'div', class: className = '' } = Astro.props;
---
<Tag class={`container ${className}`}>
  <slot />
</Tag>

<style>
  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-padding);
    width: 100%;
  }
</style>
