---
import { useTranslations, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const solutions = [1, 2, 3, 4];
---

<section class="industry-section" aria-labelledby="industry-title">
  <div class="industry-section__inner">
    <div class="industry-section__content">
      <p class="industry-section__eyebrow" aria-hidden="true">{t('industry.solutions.eyebrow')}</p>
      <h2 id="industry-title">{t('industry.solutions.title')}</h2>
      <div class="industry-section__copy">
        <p>{t('industry.solutions.body1')}</p>
        <p>{t('industry.solutions.body2')}</p>
      </div>

      <div class="industry-section__solutions">
        {
          solutions.map((item) => (
            <article class="industry-solution">
              <h3>{t(`industry.solutions.s${item}.title`)}</h3>
              <p>{t(`industry.solutions.s${item}.body`)}</p>
            </article>
          ))
        }
      </div>
    </div>

    <div class="industry-section__mockup">
      <img
        src="/brand/methodology-analytics.webp"
        alt={t('industry.solutions.placeholder')}
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  .industry-section {
    background: white;
    padding-block: var(--space-32);
    padding-inline: var(--container-padding);
  }

  .industry-section__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    gap: var(--space-12);
    align-items: start;
  }

  .industry-section__content {
    max-width: 680px;
  }

  .industry-section__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(32, 30, 30, 0.44);
    margin-bottom: var(--space-3);
  }

  .industry-section__copy {
    margin-top: var(--space-6);
    display: grid;
    gap: var(--space-4);
  }

  .industry-section__copy p {
    color: rgba(32, 30, 30, 0.74);
    font-size: clamp(1.0625rem, 1.3vw, 1.1875rem);
  }

  .industry-section__solutions {
    margin-top: var(--space-8);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .industry-solution {
    border-left: 3px solid var(--color-amarillo);
    padding-left: var(--space-4);
  }

  .industry-solution h3 {
    font-size: var(--text-h4);
    line-height: 1.25;
  }

  .industry-solution p {
    margin-top: var(--space-2);
    color: rgba(32, 30, 30, 0.68);
    font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
  }

  .industry-section__mockup {
    min-height: 360px;
    aspect-ratio: 1;
    border: 1px solid rgba(32, 30, 30, 0.08);
    border-radius: var(--radius-sm);
    background:
      linear-gradient(135deg, rgba(102, 179, 255, 0.18), rgba(255, 181, 0, 0.16)),
      var(--color-aliceblue);
    display: grid;
    place-items: center;
    overflow: hidden;
    padding: var(--space-8);
  }

  .industry-section__mockup img {
    width: 100%;
    height: 100%;
    max-height: 520px;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  @media (min-width: 48em) {
    .industry-section__solutions {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-5);
    }
  }

  @media (min-width: 64em) {
    .industry-section__inner {
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.8fr);
      align-items: center;
    }
  }

  @media (max-width: 47.999em) {
    .industry-section {
      padding-block: var(--space-24);
    }
  }
</style>
