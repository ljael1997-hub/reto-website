---
import Card from './Card.astro';
import esJson from '../i18n/es.json';
import enJson from '../i18n/en.json';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const dict = lang === 'en' ? enJson : esJson;
const { title, items } = dict.home.benefits;

// Simple geometric SVG icons in --color-amarillo (#FFB500)
const icons = [
  // Circle
  `<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><circle cx="24" cy="24" r="20" fill="#FFB500"/></svg>`,
  // Diamond (rotated square)
  `<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><polygon points="24,4 44,24 24,44 4,24" fill="#FFB500"/></svg>`,
  // Triangle
  `<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><polygon points="24,5 44,43 4,43" fill="#FFB500"/></svg>`,
  // Hexagon
  `<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><polygon points="24,3 42,13.5 42,34.5 24,45 6,34.5 6,13.5" fill="#FFB500"/></svg>`,
];
---
<section class="benefits" id="beneficios">
  <div class="benefits__container">
    <h2 class="benefits__title">{title}</h2>
    <div class="benefits__grid" role="list">
      {items.map((item, i) => (
        <div role="listitem">
          <Card>
            <div class="benefit-card">
              <div class="benefit-card__icon" set:html={icons[i]} />
              <h3 class="benefit-card__title">{item.title}</h3>
              <p class="benefit-card__desc">{item.description}</p>
            </div>
          </Card>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits {
    background: #ffffff;
    padding-block: var(--space-24);
    padding-inline: var(--container-padding);
  }

  .benefits__container {
    max-width: var(--container-max);
    margin-inline: auto;
    width: 100%;
  }

  .benefits__title {
    text-align: center;
    color: var(--color-pelicula);
    margin-bottom: var(--space-12);
  }

  .benefits__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  /* Tablet: 2 columns */
  @media (min-width: 48em) {
    .benefits__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Desktop: 4 columns */
  @media (min-width: 64em) {
    .benefits__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .benefit-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .benefit-card__icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }

  .benefit-card__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-h3);
    color: var(--color-pelicula);
    line-height: 1.15;
  }

  .benefit-card__desc {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-body);
    color: var(--color-pelicula);
    opacity: 0.8;
    line-height: 1.6;
  }
</style>
