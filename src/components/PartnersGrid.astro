---
import esJson from '../i18n/es.json';
import enJson from '../i18n/en.json';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const dict = lang === 'en' ? enJson : esJson;
const { title, subtitle } = dict.home.partners;

const clientes = [
  { slug: 'alcon', name: 'Alcon' },
  { slug: 'gsk', name: 'GSK' },
  { slug: 'cfm', name: 'CFM' },
  { slug: 'anafam', name: 'ANAFAM' },
  { slug: 'msd', name: 'MSD' },
  { slug: 'bristol-myers-squibb', name: 'Bristol Myers Squibb' },
  { slug: 'viatris', name: 'Viatris' },
  { slug: 'silanes', name: 'Silanes' },
  { slug: 'laboratorios-grin', name: 'Laboratorios Grin' },
  { slug: 'salauno', name: 'Salauno' },
  { slug: 'corne', name: 'Corne' },
  { slug: 'ophia', name: 'Ophia' },
  { slug: 'universidad-panamericana', name: 'Universidad Panamericana' },
  { slug: 'galderma', name: 'Galderma' },
  { slug: 'udlap', name: 'UDLAP' },
  { slug: 'astellas', name: 'Astellas' },
  { slug: 'synthon', name: 'Synthon' },
  { slug: 'novo-nordisk', name: 'Novo Nordisk' },
  { slug: 'loreal', name: "L'Oréal" },
  { slug: 'ifa-celtics', name: 'IFA Celtics' },
  { slug: 'opella', name: 'Opella' },
];

// Duplicate for infinite scroll effect
const track = [...clientes, ...clientes];
---
<section class="partners" id="aliados">
  <div class="partners__container">
    <h2 class="partners__title">{title}</h2>
    {subtitle && <p class="partners__subtitle">{subtitle}</p>}

    <div class="carousel" aria-label={title}>
      <div class="carousel__track">
        {track.map((p) => (
          <div class="carousel__item">
            <img
              src={`/logos/clientes/${p.slug}.png`}
              alt={p.name}
              loading="lazy"
              decoding="async"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .partners {
    background: #ffffff;
    padding-block: var(--space-16);
    padding-inline: var(--container-padding);
    overflow: hidden;
  }

  .partners__container {
    max-width: var(--container-max);
    margin-inline: auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .partners__title {
    text-align: center;
    color: var(--color-pelicula);
    font-size: var(--text-h3);
    margin-bottom: var(--space-3);
  }

  .partners__subtitle {
    text-align: center;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-body);
    color: var(--color-pelicula);
    opacity: 0.7;
    margin-bottom: var(--space-8);
  }

  .carousel {
    width: 100vw;
    margin-inline: calc(-1 * var(--container-padding));
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .carousel__track {
    display: flex;
    gap: var(--space-8);
    width: max-content;
    animation: scroll-logos 40s linear infinite;
  }

  .carousel__track:hover {
    animation-play-state: paused;
  }

  .carousel__item {
    flex-shrink: 0;
    width: 140px;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel__item img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.6);
    transition: filter 0.3s ease;
  }

  .carousel__item img:hover {
    filter: grayscale(0%) opacity(1);
  }

  @keyframes scroll-logos {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
