---
import { useTranslations, type Lang } from '../../i18n/utils';
import Button from '../Button.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const allies = [1, 2, 3, 4];
---

<section class="allies-section" aria-labelledby="allies-title">
  <div class="allies-section__inner">
    <div class="allies-section__heading">
      <h2 id="allies-title">{t('paths.allies.title')}</h2>
      <p>{t('paths.allies.subtitle')}</p>
    </div>

    <div class="allies-grid">
      {allies.map((i) => (
        <article class="ally-card">
          <h3>{t(`paths.allies.a${i}.title`)}</h3>
          <p>{t(`paths.allies.a${i}.body`)}</p>
        </article>
      ))}
    </div>

    <div class="allies-section__cta">
      <Button href="/contacto" variant="primary">Solicitar información</Button>
    </div>
  </div>
</section>

<style>
  .allies-section {
    background: var(--color-pelicula);
    padding-block: var(--space-24);
    padding-inline: var(--container-padding);
  }

  .allies-section__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-12);
  }

  .allies-section__heading {
    text-align: center;
    max-width: 640px;
  }

  .allies-section__heading h2 {
    color: #ffffff;
  }

  .allies-section__heading p {
    margin-top: var(--space-4);
    color: rgba(255,255,255,0.7);
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
  }

  .allies-grid {
    width: 100%;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }

  @media (min-width: 48em) {
    .allies-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .ally-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-md);
    padding: var(--space-6);
  }

  .ally-card h3 {
    color: var(--color-amarillo);
    font-size: var(--text-h4);
    margin-bottom: var(--space-2);
  }

  .ally-card p {
    color: rgba(255,255,255,0.7);
    font-size: 0.9375rem;
    line-height: 1.6;
  }
</style>
