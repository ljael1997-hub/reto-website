---
import { useTranslations, type Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
  number: string;
  titleKey: string;
  descriptionKey: string;
  placeholderTextKey: string;
  imageSrc: string;
  bgColor: 'white' | 'aliceblue';
  imageOnLeft?: boolean;
}

const {
  lang,
  number,
  titleKey,
  descriptionKey,
  placeholderTextKey,
  imageSrc,
  bgColor,
  imageOnLeft = false,
} = Astro.props;
const t = useTranslations(lang);
---

<section class={`pillar-section pillar-section--${bgColor}`} aria-labelledby={`pillar-${number}-title`}>
  <div class={`pillar-section__inner ${imageOnLeft ? 'pillar-section__inner--image-left' : ''}`}>
    <div class="pillar-section__content">
      <p class="pillar-section__number" aria-hidden="true">{number}</p>
      <h2 id={`pillar-${number}-title`}>{t(titleKey)}</h2>
      <p class="pillar-section__description">{t(descriptionKey)}</p>
    </div>

    <div class="pillar-section__visual">
      <img src={imageSrc} alt={t(placeholderTextKey)} loading="lazy" />
    </div>
  </div>
</section>

<style>
  .pillar-section {
    padding-block: var(--space-32);
    padding-inline: var(--container-padding);
  }

  .pillar-section--white {
    background: white;
  }

  .pillar-section--aliceblue {
    background: var(--color-aliceblue);
  }

  .pillar-section__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    gap: var(--space-12);
    align-items: center;
  }

  .pillar-section__content {
    max-width: 640px;
  }

  .pillar-section__number {
    color: var(--color-amarillo);
    font-family: var(--font-display);
    font-size: clamp(4rem, 9vw, 8rem);
    font-weight: 800;
    line-height: 0.85;
    margin-bottom: var(--space-6);
  }

  .pillar-section__description {
    margin-top: var(--space-6);
    color: rgba(32, 30, 30, 0.74);
    font-size: clamp(1.125rem, 1.4vw, 1.25rem);
  }

  .pillar-section__visual {
    min-height: 320px;
    aspect-ratio: 1.08;
    border: 1px solid rgba(32, 30, 30, 0.08);
    border-radius: var(--radius-sm);
    background:
      linear-gradient(135deg, rgba(102, 179, 255, 0.22), rgba(255, 181, 0, 0.16)),
      #eef3f7;
    display: grid;
    place-items: center;
    padding: var(--space-8);
    overflow: hidden;
  }

  .pillar-section__visual img {
    width: 100%;
    height: 100%;
    max-height: 440px;
    object-fit: contain;
    border-radius: var(--radius-sm);
  }

  @media (min-width: 64em) {
    .pillar-section__inner {
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.86fr);
    }

    .pillar-section__inner--image-left {
      grid-template-columns: minmax(320px, 0.86fr) minmax(0, 1fr);
    }

    .pillar-section__inner--image-left .pillar-section__visual {
      order: -1;
    }
  }

  @media (max-width: 47.999em) {
    .pillar-section {
      padding-block: var(--space-24);
    }

    .pillar-section__visual {
      min-height: 260px;
    }
  }
</style>
