---
import ContactForm from '../components/forms/ContactForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
---

<BaseLayout
  title="Contacto"
  description="Cuéntanos sobre tu institución. Respondemos en máximo 48 horas hábiles."
  lang={lang}
>
  <section class="contact-hero" aria-labelledby="contact-hero-title">
    <div class="contact-hero__inner">
      <h1 id="contact-hero-title">{t('contact.hero.h1')}</h1>
      <p>{t('contact.hero.subtitle')}</p>
    </div>
  </section>

  <section class="contact-body" aria-label="Formulario de contacto">
    <div class="contact-body__inner">

      <div class="contact-body__form">
        <h2 id="contact-form-heading" class="sr-only">{t('contact.hero.h1')}</h2>
        <ContactForm lang={lang} />
      </div>

      <aside class="contact-body__sidebar" aria-labelledby="sidebar-title">
        <h2 id="sidebar-title" class="sidebar-title">{t('contact.sidebar.title')}</h2>

        <ul class="sidebar-list">
          <li class="sidebar-item">
            <span class="sidebar-item__label">{t('contact.sidebar.email.label')}</span>
            <a
              href={`mailto:${t('contact.sidebar.email.value')}`}
              class="sidebar-item__value sidebar-item__value--link"
            >
              {t('contact.sidebar.email.value')}
            </a>
          </li>
          <li class="sidebar-item">
            <span class="sidebar-item__label">{t('contact.sidebar.location.label')}</span>
            <span class="sidebar-item__value">{t('contact.sidebar.location.value')}</span>
          </li>
          <li class="sidebar-item">
            <span class="sidebar-item__label">{t('contact.sidebar.response.label')}</span>
            <span class="sidebar-item__value">{t('contact.sidebar.response.value')}</span>
          </li>
        </ul>
      </aside>

    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────── */
  .contact-hero {
    background: var(--color-aliceblue);
    padding-block: var(--space-16);
    padding-inline: var(--container-padding);
  }

  .contact-hero__inner {
    max-width: 760px;
    margin-inline: auto;
    text-align: center;
  }

  .contact-hero p {
    margin-top: var(--space-4);
    color: rgba(32, 30, 30, 0.72);
    font-family: var(--font-body);
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
  }

  /* ── Body ──────────────────────────────────────────────────────────── */
  .contact-body {
    background: white;
    padding-block: var(--space-24);
    padding-inline: var(--container-padding);
  }

  .contact-body__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: grid;
    gap: var(--space-16);
  }

  /* ── Sidebar ───────────────────────────────────────────────────────── */
  .sidebar-title {
    font-size: var(--text-h4);
    margin-bottom: var(--space-6);
  }

  .sidebar-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .sidebar-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid rgba(32, 30, 30, 0.08);
  }

  .sidebar-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .sidebar-item__label {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(32, 30, 30, 0.44);
  }

  .sidebar-item__value {
    color: var(--color-pelicula);
    font-size: clamp(1rem, 1.2vw, 1.125rem);
    font-weight: 500;
  }

  .sidebar-item__value--link {
    text-decoration: none;
    color: var(--color-pelicula);
  }

  .sidebar-item__value--link:hover {
    text-decoration: underline;
  }

  /* Utility */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Desktop layout ────────────────────────────────────────────────── */
  @media (min-width: 64em) {
    .contact-body__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 320px);
      align-items: start;
      column-gap: var(--space-8);
    }

    .contact-body__sidebar {
      border-left: 1px solid rgba(32, 30, 30, 0.08);
      padding-left: var(--space-8);
    }
  }

  @media (max-width: 47.999em) {
    .contact-body {
      padding-block: var(--space-16);
    }
  }
</style>
