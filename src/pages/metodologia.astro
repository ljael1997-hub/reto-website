---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';
import PillarSection from '../components/methodology/PillarSection.astro';
import AxesSection from '../components/methodology/AxesSection.astro';

const lang = 'es';
const t = useTranslations(lang);
const pillars = [
  { number: '01', index: 1, bgColor: 'white', imageOnLeft: false, imageSrc: '/brand/methodology-accessibility.webp' },
  { number: '02', index: 2, bgColor: 'aliceblue', imageOnLeft: true, imageSrc: '/brand/methodology-cases.webp' },
  { number: '03', index: 3, bgColor: 'white', imageOnLeft: false, imageSrc: '/brand/methodology-gamification.webp' },
  { number: '04', index: 4, bgColor: 'aliceblue', imageOnLeft: true, imageSrc: '/brand/methodology-analytics.webp' },
  { number: '05', index: 5, bgColor: 'white', imageOnLeft: false, imageSrc: '/brand/methodology-personalization.webp' },
] as const;

const alianzas = [
  { slug: 'imss-hospital', name: 'IMSS Hospital de Cardiología' },
  { slug: 'grehta', name: 'GREHTA' },
  { slug: 'citic-mx', name: 'CITIC MX' },
  { slug: 'uabc', name: 'UABC' },
  { slug: 'hospital-zambrano-hellion', name: 'Hospital Zambrano Hellion TecSalud' },
  { slug: 'american-college-cardiology', name: 'American College of Cardiology' },
  { slug: 'fundacion-piel-con-vida', name: 'Fundación Piel con Vida' },
  { slug: 'academia-mexicana-pediatria', name: 'Academia Mexicana de Pediatría' },
  { slug: 'instituto-cardiologia-ignacio-chavez', name: 'Instituto de Cardiología Ignacio Chávez' },
  { slug: 'google', name: 'Google' },
  { slug: 'instituto-perinatologia', name: 'Instituto Nacional de Perinatología' },
  { slug: 'usc', name: 'USC University of Southern California' },
  { slug: 'pronadameg', name: 'PRONADAMEG' },
  { slug: 'sociedad-mexicana-cardiologia', name: 'Sociedad Mexicana de Cardiología' },
  { slug: 'fundacion-imss', name: 'Fundación IMSS' },
  { slug: 'derosearch', name: 'DeROsearch' },
  { slug: 'anafam', name: 'ANAFAM' },
  { slug: 'cfm', name: 'CFM' },
];
---

<BaseLayout
  title="Metodología"
  description="Cinco pilares que sostienen cada ruta educativa de Reto."
  lang={lang}
>
  <section class="methodology-hero" aria-labelledby="methodology-title">
    <div class="methodology-hero__inner">
      <h1 id="methodology-title">{t('methodology.hero.h1')}</h1>
      <p>{t('methodology.hero.subtitle')}</p>
    </div>
  </section>

  {
    pillars.map((pillar) => (
      <PillarSection
        lang={lang}
        number={pillar.number}
        titleKey={`methodology.pillar${pillar.index}.title`}
        descriptionKey={`methodology.pillar${pillar.index}.description`}
        placeholderTextKey={`methodology.pillar${pillar.index}.placeholder`}
        imageSrc={pillar.imageSrc}
        bgColor={pillar.bgColor}
        imageOnLeft={pillar.imageOnLeft}
      />
    ))
  }

  <AxesSection lang={lang} />

  <section class="alianzas-metodologia">
    <div class="alianzas-metodologia__container">
      <h2 class="alianzas-metodologia__title">Alianzas con las que nos apoyamos a crecer, investigar y validar</h2>
      <div class="carousel">
        <div class="carousel__track">
          {[...alianzas, ...alianzas].map((p) => (
            <div class="carousel__item">
              <img
                src={`/logos/alianzas/${p.slug}.png`}
                alt={p.name}
                loading="lazy"
                decoding="async"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .methodology-hero {
    min-height: 50vh;
    background: var(--color-aliceblue);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-16);
    padding-inline: var(--container-padding);
  }

  .methodology-hero__inner {
    max-width: 960px;
    margin-inline: auto;
    text-align: center;
  }

  .methodology-hero p {
    max-width: 720px;
    margin: var(--space-6) auto 0;
    color: rgba(32, 30, 30, 0.76);
    font-family: var(--font-body);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 500;
  }

  .alianzas-metodologia {
    background: #f8f8f8;
    padding-block: var(--space-16);
    padding-inline: var(--container-padding);
    overflow: hidden;
  }

  .alianzas-metodologia__container {
    max-width: var(--container-max);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .alianzas-metodologia__title {
    text-align: center;
    color: var(--color-pelicula);
    font-size: var(--text-h3);
    margin-bottom: var(--space-8);
    max-width: 640px;
  }

  .carousel {
    width: 100vw;
    margin-inline: calc(-1 * var(--container-padding));
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .carousel__track {
    display: flex;
    gap: var(--space-8);
    width: max-content;
    animation: scroll-logos-reverse 40s linear infinite;
  }

  .carousel__track:hover {
    animation-play-state: paused;
  }

  .carousel__item {
    flex-shrink: 0;
    width: 140px;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel__item img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.6);
    transition: filter 0.3s ease;
  }

  .carousel__item img:hover {
    filter: grayscale(0%) opacity(1);
  }

  @keyframes scroll-logos-reverse {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }
</style>
