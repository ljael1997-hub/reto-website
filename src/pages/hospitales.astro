---
import Button from '../components/Button.astro';
import AudienceBenefits from '../components/audiences/AudienceBenefits.astro';
import AudienceProgramSection from '../components/audiences/AudienceProgramSection.astro';
import CaseStudy from '../components/audiences/CaseStudy.astro';
import FinalCta from '../components/audiences/FinalCta.astro';
import AlliancesCarousel from '../components/audiences/AlliancesCarousel.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);
---

<BaseLayout
  title="Para hospitales"
  description="Una plataforma para hospitales que necesitan formar y certificar a su personal médico de forma continua, medible y respaldada institucionalmente."
  lang={lang}
>
  <section class="hospitals-hero" aria-labelledby="hospitals-title">
    <div class="hospitals-hero__inner">
      <h1 id="hospitals-title">{t('hospitals.hero.h1')}</h1>
      <p>{t('hospitals.hero.subtitle')}</p>
      <Button href="/contacto" variant="secondary">{t('hospitals.hero.cta')}</Button>
    </div>
  </section>

  <AudienceProgramSection lang={lang} baseKey="hospitals.program" />
  <AudienceBenefits
    lang={lang}
    titleKey="hospitals.benefits.title"
    subtitleKey="hospitals.benefits.subtitle"
    itemBaseKey="hospitals.benefits"
  />
  <CaseStudy
    lang={lang}
    titleKey="hospitals.case.title"
    quoteKey="hospitals.case.quote"
    attributionBaseKey="hospitals.case.attribution"
    metricBaseKey="hospitals.case"
  />
  <AlliancesCarousel />
  <FinalCta
    lang={lang}
    titleKey="hospitals.finalCta.title"
    bodyKey="hospitals.finalCta.body"
    buttonKey="hospitals.finalCta.button"
    href="/contacto"
  />
</BaseLayout>

<style>
  .hospitals-hero {
    min-height: 50vh;
    background: var(--color-aliceblue);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-16);
    padding-inline: var(--container-padding);
  }

  .hospitals-hero__inner {
    max-width: 960px;
    margin-inline: auto;
    text-align: center;
  }

  .hospitals-hero p {
    max-width: 760px;
    margin: var(--space-6) auto 0;
    color: rgba(32, 30, 30, 0.76);
    font-family: var(--font-body);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 500;
  }

  .hospitals-hero :global(.btn) {
    margin-top: var(--space-8);
  }
</style>
