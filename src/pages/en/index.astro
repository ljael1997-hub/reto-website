---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';
import Card from '../../components/Card.astro';
---
<BaseLayout title="Design System" lang="en">

  <Section background="aliceblue" id="home">
    <Container>
      <h1>Reto Design System</h1>
      <p style="max-width: 60ch; margin-top: var(--space-4);">
        This page exists only to verify the visual system is correctly applied.
        When the real site is ready, this page will be replaced by the Home.
      </p>
      <div style="display: flex; gap: var(--space-4); margin-top: var(--space-8); flex-wrap: wrap;">
        <Button variant="primary">Primary CTA</Button>
        <Button variant="secondary">Secondary CTA</Button>
      </div>
    </Container>
  </Section>

  <Section background="pelicula">
    <Container>
      <h2>Section on dark background</h2>
      <p style="margin-top: var(--space-4); max-width: 60ch;">
        This section demonstrates the use of "Classic Film" color as background, with aliceblue text.
      </p>
    </Container>
  </Section>

  <Section background="amarillo">
    <Container>
      <h2>Section on Mellow yellow</h2>
      <p style="margin-top: var(--space-4); max-width: 60ch;">
        Yellow is the primary brand color. It is used in emphasis sections like a manifesto, not in buttons.
      </p>
    </Container>
  </Section>

  <Section background="rosa">
    <Container>
      <h2>Section on pink</h2>
      <p style="margin-top: var(--space-4); max-width: 60ch;">
        Pink is used in warm blocks and as contrast with yellow.
      </p>
    </Container>
  </Section>

  <Section background="aliceblue">
    <Container>
      <h2>Cards</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--space-6); margin-top: var(--space-8);">
        <Card>
          <h4>Access to medical communities</h4>
          <p style="margin-top: var(--space-3);">Connect with active physicians, segmented by specialty.</p>
        </Card>
        <Card>
          <h4>Education with real engagement</h4>
          <p style="margin-top: var(--space-3);">Learning experiences based on clinical cases.</p>
        </Card>
        <Card>
          <h4>Measurable impact</h4>
          <p style="margin-top: var(--space-3);">Measure engagement, interaction and performance evolution.</p>
        </Card>
      </div>
    </Container>
  </Section>

  <Section background="aliceblue">
    <Container>
      <h2>Type scale</h2>
      <div style="margin-top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-6);">
        <div>
          <p style="font-size: var(--text-tiny); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(32,30,30,0.4); margin-bottom: var(--space-2);">H1 — Bricolage Grotesque 800</p>
          <h1>Heading H1</h1>
        </div>
        <div>
          <p style="font-size: var(--text-tiny); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(32,30,30,0.4); margin-bottom: var(--space-2);">H2 — Bricolage Grotesque 800</p>
          <h2>Heading H2</h2>
        </div>
        <div>
          <p style="font-size: var(--text-tiny); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(32,30,30,0.4); margin-bottom: var(--space-2);">H3 — Bricolage Grotesque 800</p>
          <h3>Heading H3</h3>
        </div>
        <div>
          <p style="font-size: var(--text-tiny); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(32,30,30,0.4); margin-bottom: var(--space-2);">H4 — Bricolage Grotesque 700</p>
          <h4>Heading H4</h4>
        </div>
        <div>
          <p style="font-size: var(--text-tiny); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(32,30,30,0.4); margin-bottom: var(--space-2);">Body — Inter 400</p>
          <p>Body text. Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
        </div>
      </div>
    </Container>
  </Section>

</BaseLayout>
